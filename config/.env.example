# Cerberus Asist — Environment Configuration
# Copy to .env and fill in your values
#
# Server Deployment Mode:
#   Sistem ini dirancang untuk berjalan sebagai standalone server
#   yang dapat dikendalikan sepenuhnya via SSH remote dan web dashboard.
#
# Quick Start:
#   1. sudo bash run.sh --deploy     # Full server bootstrap + Cerberus setup
#   2. sudo bash run.sh --start      # Start all services
#   3. Buka http://<server-ip>:7860  # Web dashboard
#   4. ssh admin@<server-ip>         # Remote SSH access

# ─── Required ──────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=                          # Your Telegram bot token from @BotFather

# ─── Optional: Security ───────────────────────────────────────────────────
COMMAND_SECRET=                          # HMAC signing secret (auto-generated if empty)
PAIR_TTL_SEC=86400                       # Pairing TTL in seconds (default: 24h)
TELEGRAM_CHAT_ID=                        # Whitelist chat ID (optional)

# ─── Optional: LLM Server ─────────────────────────────────────────────────
LLAMA_API=http://127.0.0.1:8080/v1       # llama.cpp API endpoint
PORT_LLM=8080                            # LLM server port

# ─── Optional: Paths ──────────────────────────────────────────────────────
CERBERUS_ASIST_BASE=/opt/cerberus_asist  # Base installation directory
TARGET_BASE=/opt/cerberus_asist          # Install target (for run.sh --deploy)
RAG_DB=/opt/cerberus_asist/rag/chroma_db # ChromaDB vector store location
RAG_DOCS=/opt/cerberus_asist/rag/documents # Document directory for RAG ingestion
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_CHUNK_SIZE=1000                      # Text chunk size in characters

# ─── Optional: Dashboard ──────────────────────────────────────────────────
PORT=7860                                # Flask dashboard port

# ─── Optional: Tailscale ─────────────────────────────────────────────────
# Tailscale mesh VPN — akses server dari mana saja via Tailscale network.
# Dapatkan auth key dari: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=                      # Tailscale pre-auth key (optional, untuk headless setup)
TAILSCALE_USE_AUTH_KEY=yes               # Gunakan auth key untuk otentikasi (yes/no, default: yes)
TAILSCALE_ADVERTISE_ROUTES=              # Advertise routes CIDR (opsional, misal: 192.168.1.0/24)
TAILSCALE_TAG=                           # Tag untuk device (opsional, misal: tag:server)
TAILSCALE_HOSTNAME=cerberus-asist        # Hostname di Tailscale network (default: cerberus-asist)
TAILSCALE_ACCEPT_DNS=yes                 # Accept Tailscale DNS (yes/no, default: yes)
TAILSCALE_ACCEPT_ROUTES=yes              # Accept subnet routes (yes/no, default: yes)

# ═══════════════════════════════════════════════════════════════════════════
# SERVER DEPLOYMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# --- Server Bootstrap ---
# Used by: sudo bash run.sh --server / --deploy
ADMIN_USER=admin                         # Admin username for SSH access
ADMIN_PUBKEY=                            # SSH public key for admin (ssh-rsa AAA...)
SSH_PORT=22                              # SSH server port
HOSTNAME_TAG=cerberus-asist              # Server hostname
TIMEZONE=Asia/Makassar                   # Server timezone
NTP_SERVER=id.pool.ntp.org               # NTP server

# --- Security Features ---
ENABLE_FIREWALL=yes                      # Enable UFW firewall (yes/no)
ENABLE_FAIL2BAN=yes                      # Enable Fail2Ban SSH protection (yes/no)
ENABLE_AUTO_UPGRADE=yes                  # Automatic security updates (yes/no)
ENABLE_SWAP=yes                          # Create swap file (yes/no)
SWAP_SIZE_GB=2                           # Swap file size in GB

# --- Backup ---
BACKUP_DIR=/var/backups/cerberus_asist   # Backup storage directory
RETENTION_DAYS=30                        # Backup retention in days
GPG_RECIPIENT=                           # GPG key for encrypted backups (optional)

# --- Monitoring ---
HEALTH_CHECK_INTERVAL=5                  # Health check interval in minutes
ALERT_THRESHOLD_DISK=85                  # Disk usage warning threshold (%)
ALERT_THRESHOLD_MEM=80                   # Memory usage warning threshold (%)
CRITICAL_THRESHOLD_DISK=95               # Disk usage critical threshold (%)
CRITICAL_THRESHOLD_MEM=90                # Memory usage critical threshold (%)

# --- SSH Keys ---
SSH_KEY_DIR=/opt/cerberus_asist/ssh-keys # Generated SSH keys directory
SSH_KEY_NAME=cerberus_controller         # Default SSH key name
SSH_KEY_TYPE=ed25519                     # Key type (ed25519, rsa, ecdsa)
SSH_KEY_COMMENT=cerberus-asist-controller # Key comment